#include <iostream>
using namespace std;

int main() {
    double monto, porcentaje;
    cout << "Ingrese el monto inicial: ";
    cin >> monto;
    cout << "Ingrese el porcentaje de incremento: ";
    cin >> porcentaje;
    cout << "Nuevo monto: " << monto + (monto * porcentaje / 100) << endl;
    return 0;
}
